# Backend runtime
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
COMFYUI_SERVER=127.0.0.1:8188
DATABASE_URL=sqlite:///./ainfluencer.db
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=
DEMO_MODE=false
ENABLE_ADVANCED=true
ENABLE_UPSCALE=true
ENABLE_FACE_RESTORE=true
ENABLE_BATCH=true
ENABLE_HIGH_RES=true
DEMO_MAX_WIDTH=1024
DEMO_MAX_HEIGHT=1024
DEMO_MAX_BATCH=1
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500
MAX_REQUEST_SIZE_MB=25
REQUEST_TIMEOUT_SECONDS=120
MAX_CONCURRENT_JOBS=1

# GPU/optimization toggles
GPU_MEMORY_FRACTION=0.9
USE_MIXED_PRECISION=true

# Third-party (optional)
HIVE_API_KEY=
SENSITY_API_KEY=
AI_OR_NOT_API_KEY=

# Frontend / API URLs
# Public bundle reads NEXT_PUBLIC_*; server reads the non-prefixed values.
NEXT_PUBLIC_API_URL=http://localhost:8000
BACKEND_URL=http://localhost:8000
COMFYUI_URL=http://localhost:8188
NEXT_PUBLIC_COMFYUI_URL=http://localhost:8188
NEXT_PUBLIC_DEMO_MODE=false
NEXT_PUBLIC_ENABLE_ADVANCED=true
NEXT_PUBLIC_ENABLE_UPSCALE=true
NEXT_PUBLIC_ENABLE_FACE_RESTORE=true
NEXT_PUBLIC_ENABLE_BATCH=true
NEXT_PUBLIC_ENABLE_HIGH_RES=true
NEXT_PUBLIC_DEMO_MAX_WIDTH=1024
NEXT_PUBLIC_DEMO_MAX_HEIGHT=1024
NEXT_PUBLIC_DEMO_MAX_BATCH=1

