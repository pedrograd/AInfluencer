# Deployment-safe environment template
# Copy to env.deploy (not committed) and use values for GitHub secrets/providers.

# --- GitHub Action / provider tokens ---
VERCEL_TOKEN=
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
RENDER_API_KEY=
RENDER_SERVICE_ID=

# --- Public frontend config (safe to expose) ---
NEXT_PUBLIC_API_URL=https://your-backend.onrender.com
NEXT_PUBLIC_COMFYUI_URL=
NEXT_PUBLIC_DEMO_MODE=true
NEXT_PUBLIC_ENABLE_ADVANCED=false
NEXT_PUBLIC_ENABLE_UPSCALE=false
NEXT_PUBLIC_ENABLE_FACE_RESTORE=false
NEXT_PUBLIC_ENABLE_BATCH=false
NEXT_PUBLIC_ENABLE_HIGH_RES=false
NEXT_PUBLIC_DEMO_MAX_WIDTH=1024
NEXT_PUBLIC_DEMO_MAX_HEIGHT=1024
NEXT_PUBLIC_DEMO_MAX_BATCH=1

# --- Backend (Render) ---
API_HOST=0.0.0.0
API_PORT=8000
PORT=8000
ALLOWED_ORIGINS=https://your-frontend.vercel.app
COMFYUI_SERVER=127.0.0.1:8188
DATABASE_URL=sqlite:///./ainfluencer.db
REDIS_URL=
REDIS_PASSWORD=
DEMO_MODE=true
ENABLE_ADVANCED=false
ENABLE_UPSCALE=false
ENABLE_FACE_RESTORE=false
ENABLE_BATCH=false
ENABLE_HIGH_RES=false
DEMO_MAX_WIDTH=1024
DEMO_MAX_HEIGHT=1024
DEMO_MAX_BATCH=1
RATE_LIMIT_PER_MINUTE=30
RATE_LIMIT_PER_HOUR=500
MAX_REQUEST_SIZE_MB=25
REQUEST_TIMEOUT_SECONDS=120
MAX_CONCURRENT_JOBS=1

# --- Optional API integrations (leave empty for demo) ---
HIVE_API_KEY=
SENSITY_API_KEY=
AI_OR_NOT_API_KEY=

